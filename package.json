{
  "private": true,
  "name": "pb",
  "version": "1.0.0",
  "description": "Pastebin based on Cloudflare worker",
  "repository": "https://github.com/SharzyL/pastebin-worker",
  "type": "module",
  "scripts": {
    "deploy": "wrangler deploy",
    "build:frontend": "vite build frontend --outDir ../dist/frontend --emptyOutDir",
    "build:frontend:dev": "vite build frontend --mode development --outDir ../dist/frontend --emptyOutDir",
    "dev:frontend": "vite serve frontend --mode development",
    "preview:frontend": "vite preview --outDir dist/frontend",
    "dev": "wrangler dev --var DEPLOY_URL:http://localhost:8787 INDEX_PAGE_TITLE:\"Pastebin Worker (dev)\" --port 8787",
    "gentypes": "wrangler types --strict-vars false",
    "build": "wrangler deploy --dry-run --outdir=dist",
    "delete-paste": "wrangler kv key delete --binding PB",
    "test": "vitest",
    "fmt": "prettier --write .",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "coverage": "vitest run --coverage"
  },
  "author": "SharzyL <me@sharzy.in>",
  "license": "MIT",
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.8",
    "@craftamap/esbuild-plugin-html": "^0.9.0",
    "@eslint/js": "^10.0.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.9.1",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-istanbul": "4.1.7",
    "eslint": "^10.4.0",
    "jsdom": "^29.1.1",
    "msw": "^2.14.6",
    "prettier": "^3.8.3",
    "toml": "^4.1.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "vite": "^8.0.14",
    "vitest": "4.1.7",
    "wrangler": "^4.93.1"
  },
  "prettier": {
    "singleQuote": false,
    "semi": false,
    "trailingComma": "all",
    "tabWidth": 2,
    "printWidth": 120
  },
  "dependencies": {
    "@mjackson/multipart-parser": "^0.10.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/bcrypt": "^6.0.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "bcrypt-ts": "^8.0.1",
    "github-slugger": "^2.0.0",
    "highlight.js": "^11.11.1",
    "marked": "^18.0.4",
    "mime": "^4.1.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwindcss": "^4.3.0",
    "xss": "^1.0.15"
  },
  "resolutions": {
    "stringify-entities": "4.0.2"
  }
}
